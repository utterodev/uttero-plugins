{
  "name": "uttero",
  "version": "0.1.0",
  "description": "Voice for agents — Uttero CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "uttero": "./bin/uttero"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --external commander --external open",
