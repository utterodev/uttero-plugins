    "directory": "cli"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "open": "^10.0.0",
    "@modelcontextprotocol/sdk": "^1.12.1"
  }
}
